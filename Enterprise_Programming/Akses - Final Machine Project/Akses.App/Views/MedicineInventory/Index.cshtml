@model List<MedicineInventoryVM>

<a asp-controller="Home" asp-action="Index" class="btn btn-primary">
    <i class="fas fa-solid fa-house"></i>
    Back to Homepage
</a>
<a asp-controller="MedicineInventory" asp-action="Add" class="btn btn-success">
    <i class="fas fa-brands fa-product-hunt"></i>
    Add New Inventory Entry
</a>

@if (Model.Count() < 1)
{
    <div class="alert alear-info">
        No Item Record Found
    </div>
}
else
{
    <table class="table table-striped table-hover" id="MedicineInventoryTable">
                <thead> 
                    <tr>
                       
                        <th>Medicine Name</th>
                        <th>Manufacturing Date</th>
                        <th>Expiration Date </th>
                        <th>Price </th>
                         <th>In-Stock</th>
                    
                   
                        
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                {
                    <tr>
                        <td> @item.MedicineName</td>
                        <td> @item.MFGDate</td>
                        <td> @item.ExpiryDate</td>
                        <td> @item.Price</td>
                        <td> @item.Quantity</td>
                        
                            
                            <td>
                               <a asp-controller="MedicineInventory" asp-action="Edit" asp-route-id="@item.MedicineID" class="btn btn-info">
                                  <i class="fas fa-edit"></i>
                                Edit
                                </a>                             
                              <button class="btn btn-danger deleteBtn" data-id="@item.MedicineID">
                                  <i class="fas fa-trash"></i>
                                  Delete
                              </button>
                           
                          </td>
                    </tr>
                }
                </tbody>
            </table>
            }

<form id="DeleteForm" asp-controller="MedicineInventory" asp-action="Delete" method="post" >
    <input type="hidden" id="HiddenMedicineID" name="MedicineID" value=""/>
</form>


@section Scripts {
    <script>
        $(document).ready( function () {
         $('#MedicineInventoryTable').DataTable();
    });

    $('.deleteBtn').click(function(e) {
        swal({
            title: "Are you sure?",
            text: "Are you sure you want to delete this record?",
            icon: "warning",
            buttons: true,
            dangerMode: true
        }).then((confirm) => {
            if (confirm) {
                var btn = $(this);
                var id = btn.data("id");
                $("#HiddenMedicineID").val(id);
                $("#DeleteForm").submit();
            }
        });
    });
    </script>
    }
