@model List<OrderHeader>


<a asp-controller="Home" asp-action="Index" class="btn btn-primary">
    <i class="fas fa-solid fa-house"></i>
    Back to Homepage
</a>
<a asp-controller="PurchaseMedicine" asp-action="Add" class="btn btn-success">
    <i class="fa-solid fa-cart-shopping"></i>
    Purchase Order
</a>

<br /><br />

@if (Model.Count() > 0)
{
    <table id="tablePurchase" class="table table-hover table-striped table-sm">
        <thead>
            <tr>
                <th class="text-center">Customer ID</th>
                <th class="text-center">Name</th>
                <th class="text-center">Contact No</th>
                <th class="text-center">Status</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (OrderHeader item in Model)
            {
                <tr>
                    <td class="text-center">@item.CustomerId</td>
                    <td class="text-center">@item.Customer.Name</td>
                    <td class="text-center">@item.Customer.ContactNo</td>
                    <td class="text-center">@item.Status</td>
                    <td class="text-center">
                        <button type="button" class="btn btn-info btn-sm Summary" data-oid="@item.Id"
                            data-bs-toggle="modal" data-bs-target="#modalSummary">
                            Summary
                        </button>
                        @if(item.Status == "Pending Order")
                        {
                          <button type="button" class="btn btn-success btn-sm Complete" data-oid="@item.Id">
                            <i class="fas fa-diagram-successor"></i>
                            Order Complete
                        </button>

                        <button type="button" class="btn btn-success btn-sm Cancelled" data-oid="@item.Id">
                            <i class="fas fa-diagram-successor"></i>
                            Cancelled
                        </button>
                        }
                       
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <div class="alert alert-info">
        No Purchase Order Record
    </div>
}


<!-- Modal -->
<div class="modal fade" id="modalSummary" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl">
    <div class="modal-content">
      <div class="modal-body">
           <div id="divSummary">
                    @{
                        await Html.RenderPartialAsync("_Summary", new PurchaseOrderVM());
                    }
           </div>
           <div class="text-end">
               <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
           </div>
      </div>
    </div>
  </div>
</div>

<!-- Order Form -->
<form id="frmCompleteOrder" asp-controller="PurchaseMedicine" asp-action="Complete" method="post">
    <input type="hidden" id="inputOrderId" name="PurchaseId" />
</form>

<form id="frmCancelOrder" asp-controller="PurchaseMedicine" asp-action="Cancelled" method="post">
    <input type="hidden" id="inputOrdersId" name="PurchaseId" />
</form>

@section Scripts {
    <script>
        $('#tablePurchase').DataTable();

        $('.Summary').click(function(e) {
            var oid = $(this).data('oid');
            $.ajax({
                type: 'post',
                url: '@Url.Action("Summary", "PurchaseMedicine")',
                data: { PurchaseId :oid},
                dataType: 'html',
                success: function(result) {
                    $('#divSummary').html(result);
                },
                error: function(req, status, error) {
                    console.log(status);
                }
            })
        })

        $('.Complete').click(function(e) {
            swal({
                title: "Complete Purchase Order",
                text: "This action cannot be undone, would you like to mark this transaction as complete?",
                icon: "warning",
                buttons: true,
                dangerMode: true
            }).then(ok => {
                if (ok) {
                    var oid = $(this).data('oid');
                    $('#inputOrderId').val(oid);
                    $('#frmCompleteOrder').submit();
                }
            });
        }); 

        $('.Cancelled').click(function(e) {
            swal({
                title: "Purchase Order Has Been Cancelled?",
                text: "Mark the transaction as null.",
                icon: "warning",
                buttons: true,
                dangerMode: true
            }).then(ok => {
                if (ok) {
                    var oid = $(this).data('oid');
                    $('#inputOrdersId').val(oid);
                    $('#frmCancelOrder').submit();
                }
            });
        }); 
    </script>
}