@using Bernardo___ENTPROG___OTIS1;
@model SupplierVM

<h3> Create A New Supplier</h3>

<form asp-controller="Supplier" asp-action="Add" method="post"> 
    <div asp-validation-summary="All" class="text-danger"> </div>
    <label asp-for="CompanyName"> </label>
    <input type="text" asp-for="CompanyName" class="form-control" />
    <br/>

    <label asp-for="Address"></label>
    <input type="text" asp-for="Address" class="form-control" />
    <br/>

    <label asp-for="Representative"></label>
    <input type="text" asp-for="Representative" class="form-control" />
    <br/>

    <label asp-for="ContactNo"></label>
    <input type="text" asp-for="ContactNo" class="form-control" />
    <br/>
   

<a asp-controller="Supplier" asp-action="Index" class="btn btn-primary">
    Back
</a>
<input type="submit" value="Add Supplier" class="btn btn-success" />

</form>
