@using Bernardo___ENTPROG___OTIS1;
@model List<SupplierVM>

<a asp-controller="Home" asp-action="Index" class="btn btn-primary">
    <i class="fas fa-solid fa-house"></i>
    Back to Homepage
</a>
<a asp-controller="Supplier" asp-action="Add" class="btn btn-success">
    <i class="fas fa-solid fa-truck-field"></i>
    Add New Supplier
</a>
<br /> <br />
@if (Model.Count() < 1)
{
    <div class="aler-info">
    No Records Found
</div>
}


else
        {
            <table class="table table-striped table-hover" id="SuppliersTable">
                <thead> 
                    <tr>
                        <th>Supplier ID</th>
                        <th>Company Name</th>
                        <th>Address</th>
                        <th>Representative</th>
                        <th>Contact No.</th>
                        <th>Date Added</th>
                        <th>Date Modified</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                {
                    <tr>
                        <td> @item.SupplierID</td>
                        <td> @item.CompanyName</td>
                        <td> @item.Address</td>
                        <td> @item.Representative</td>
                        <td> @item.ContactNo</td>
                        <td> @item.DateAdded </td>
                        <td> @item.DateModified </td>
                            <td>
                              <a asp-controller="Supplier" asp-action="Edit" asp-route-id="@item.SupplierID" class="btn btn-info">
                                  <i class="fas fa-edit"></i>
                                Edit
                                </a>                             
                              <button class="btn btn-danger deleteBtn" data-id="@item.SupplierID">
                                  <i class="fas fa-trash"></i>
                                  Delete
                              </button>
                          </td>
                    </tr>
                }
                </tbody>
            </table>
        }

<form id="DeleteForm" asp-controller="Supplier" asp-action="Delete" method="post" >
    <input type="hidden" id="HiddenSupplierID" name="SupplierID" value=""/>
</form>

@section Scripts {
    <script>
        $(document).ready( function () {
         $('#SuppliersTable').DataTable();
    });

    $('.deleteBtn').click(function(e) {
        swal({
            title: "Are you sure?",
            text: "Are you sure you want to delete this record?",
            icon: "warning",
            buttons: true,
            dangerMode: true
        }).then((confirm) => {
            if (confirm) {
                var btn = $(this);
                var id = btn.data("id");
                $("#HiddenSupplierID").val(id);
                $("#DeleteForm").submit();
            }
        });
    });
    </script>
}
