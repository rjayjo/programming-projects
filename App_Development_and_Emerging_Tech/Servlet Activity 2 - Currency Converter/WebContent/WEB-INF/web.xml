<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://xmlns.jcp.org/xml/ns/javaee" xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd" id="WebApp_ID" version="4.0">
  <display-name>Servlet Activity 2 - Currency Converter</display-name>
  <welcome-file-list>
    <welcome-file>index.html</welcome-file>
    <welcome-file>index.jsp</welcome-file>
    <welcome-file>index.htm</welcome-file>
    <welcome-file>default.html</welcome-file>
    <welcome-file>default.jsp</welcome-file>
    <welcome-file>default.htm</welcome-file>
  </welcome-file-list>
  
  <servlet>
  	<servlet-name>result</servlet-name>
  	<servlet-class>com.currencyconverter.servlet.CurrencyConverterServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  	<servlet-name>result</servlet-name>
  	<url-pattern>/ConversionResult</url-pattern>
  </servlet-mapping>

  <servlet>
  	<servlet-name>convertaction</servlet-name>
  	<servlet-class>com.currencyconverter.servlet.AddValueServlet</servlet-class>
  </servlet>
  <servlet-mapping>
  	<servlet-name>convertaction</servlet-name>
  	<url-pattern>/SimpleCurrencyConverter</url-pattern>
  </servlet-mapping>


 
  
</web-app>






